{"key":"lost_in_forest","visibility":"public","severity":"low","template":"{player} got lost, returned, and blamed the trees."}
{"key":"merchant_cart","visibility":"public","severity":"medium","template":"A forest merchant says {player} made the trip memorable."}
{"key":"old_well","visibility":"public","severity":"medium","template":"The old well answered {player}. Nobody likes what it said."}
{"key":"lantern_trial","visibility":"public","severity":"medium","template":"{player} stood before the lantern trial and came away changed."}
{"key":"rival_tracks","visibility":"public","severity":"medium","template":"{player} followed fresh tracks and found a reason to check the rankings."}
{"key":"buried_door","visibility":"public","severity":"high","template":"{player} found a buried door where yesterday there was only dirt."}
